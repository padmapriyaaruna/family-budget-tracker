# Artwork Automation Engine — Environment Variables
# Copy this file to .env and fill in your values

# ── Neon PostgreSQL ─────────────────────────────────────
# Get this from your Neon dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/artwork_db?sslmode=require

# ── App Settings ────────────────────────────────────────
DEBUG=false
RENDER_DPI=150

# ── CORS ────────────────────────────────────────────────
# Your Render Static Site URL (or localhost for dev)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com
